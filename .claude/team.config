# mARC — per-repo team binding (generated by /marc:init; edit freely).
# Schema: docs/team.config.example. Format: key=value, one per line.
# Comments live on their OWN line (start with #); never inline after a value.

# --- GitHub binding ---
gh_org=NexaDuo
gh_repo=NexaDuo/nexaduo.github.io
# Team chose Issues-only (no Project board) this session, so this is left TODO.
# Two boards exist if you later want one: #2 "mARC's project", #1 "chat-services".
# Do NOT bind to an auto-created "untitled" project.
project_number=TODO_project_number

# --- Architecture authority ---
agents_doc=AGENTS.md

# --- Key source paths ---
app_paths=index.html,script.js,i18n.js,styles.css,privacy-policy/,terms-of-service/,assets/
# No IaC: static site published by GitHub Pages.
iac_paths=N/A
test_paths=tests/
ui_paths=index.html,styles.css,i18n.js,privacy-policy/,terms-of-service/

# --- Validation (the single command that proves a change works) ---
validation_command=npm test

# --- Release-phase facts ---
has_release_pipeline=true
# GitHub Actions: "Tests" (Playwright) + "pages build and deployment".
real_urls=https://nexaduo.com
# GitHub Pages, NO staging. Deploy = merge to main -> Pages publishes.
# Confirm the "pages build and deployment" run conclusion (not just Tests);
# it can fail transiently ("Deployment failed, try again later") -> `gh run rerun <id> --failed`.
release_notes=github-pages-no-staging
